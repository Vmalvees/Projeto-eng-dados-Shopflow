{
  "table_name": "customers",
  "checks": {
    "completeness": {
      "columns": ["customer_id", "first_name", "last_name", "email", "registration_date"],
      "threshold": 0.95
    },
    "uniqueness": {
      "columns": ["customer_id", "email"]
    },
    "allowed_values": {
      "segment": ["b2c", "b2b", "premium", "enterprise"]
    }
  }
}
